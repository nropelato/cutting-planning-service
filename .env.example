# ── Security ──────────────────────────────────────────────────────────────────
# API key required on every request via the X-API-KEY header.
# Change this before deploying to production.
API_KEY=super_secret_dev_key_change_in_production

# Comma-separated list of allowed CORS origins.
ALLOWED_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Solver constraints ────────────────────────────────────────────────────────
# Maximum number of distinct cut patterns the solver may generate.
MAX_PATTERNS=3

# Maximum number of fabric layers (plies) that can be stacked on the table.
MAX_PLY_LIMIT=100

# Hard time limit (seconds) for the CP-SAT solver per request.
SOLVER_TIME_LIMIT_SECONDS=30.0

# ── Uvicorn ───────────────────────────────────────────────────────────────────
# Number of uvicorn worker processes (docker-compose sets this via environment:).
WORKERS=2
