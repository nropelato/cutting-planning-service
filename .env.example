# Security
API_KEY=your_production_api_key_here
ALLOWED_CORS_ORIGINS=http://localhost:3000

# Engine Architectural & Physical Constraints
MAX_PATTERNS=3
MAX_PLY_LIMIT=100
SOLVER_TIME_LIMIT_SECONDS=30.0
MAX_TABLE_LENGTH_CM=800
FABRIC_WIDTH_CM=180
NESTING_EFFICIENCY=0.85

# Financial-Industrial TCO Parameters
LAYER_SPREADING_COST=15.00
MARKER_FIXED_BASE_COST=80.00
MARKER_PAPER_COST_PER_CM=0.15
SUBSTITUTION_ANNOYANCE_TAX=2.00

# Short-Shipping Tolerance Gates
MAX_SHORTAGE_PCT=0.05
SHORTAGE_PENALTY_MULTIPLIER=1.5

# Anomaly Tuning Knobs
DEFAULT_ANOMALY_SCALING_PCT=0.02
DEFAULT_HARD_ANOMALY_CEILING=3
